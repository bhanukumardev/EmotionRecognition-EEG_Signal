{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# EEG Emotion Recognition: Model Evaluation\n",
    "\n",
    "This notebook evaluates the trained emotion recognition model on the test dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import pickle\n",
    "import joblib\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score, classification_report, confusion_matrix,\n",
    "    precision_recall_fscore_support, roc_curve, auc\n",
    ")\n",
    "from sklearn.preprocessing import label_binarize\n",
    "import sys\n",
    "sys.path.insert(0, '/app/eeg_emotion_recognition_1806/src')\n",
    "\n",
    "# Set style\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Test Data and Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load test features and labels\n",
    "X_test = np.load('/app/eeg_emotion_recognition_1806/data/processed/X_test_features.npy')\n",
    "y_test = np.load('/app/eeg_emotion_recognition_1806/data/processed/y_test.npy')\n",
    "\n",
    "# Load model info\n",
    "with open('/app/eeg_emotion_recognition_1806/model/model_info.pkl', 'rb') as f:\n",
    "    model_info = pickle.load(f)\n",
    "\n",
    "emotions = model_info['emotions']\n",
    "print(f\"Test samples: {len(y_test)}\")\n",
    "print(f\"Emotions: {emotions}\")\n",
    "print(f\"Feature dimensions: {X_test.shape[1]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load models\n",
    "model_rf = joblib.load('/app/eeg_emotion_recognition_1806/model/emotion_model_rf.pkl')\n",
    "scaler_rf = joblib.load('/app/eeg_emotion_recognition_1806/model/scaler_rf.pkl')\n",
    "\n",
    "model_svm = joblib.load('/app/eeg_emotion_recognition_1806/model/emotion_model_svm.pkl')\n",
    "scaler_svm = joblib.load('/app/eeg_emotion_recognition_1806/model/scaler_svm.pkl')\n",
    "\n",
    "# Scale test data\n",
    "X_test_scaled_rf = scaler_rf.transform(X_test)\n",
    "X_test_scaled_svm = scaler_svm.transform(X_test)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Model Predictions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get predictions\n",
    "y_pred_rf = model_rf.predict(X_test_scaled_rf)\n",
    "y_pred_svm = model_svm.predict(X_test_scaled_svm)\n",
    "\n",
    # Get probabilities (only RF has predict_proba)
    y_prob_rf = model_rf.predict_proba(X_test_scaled_rf)
    y_prob_svm = None  # SVM trained without probability=True
    "\n",
    "# Calculate accuracies\n",
    "acc_rf = accuracy_score(y_test, y_pred_rf)\n",
    "acc_svm = accuracy_score(y_test, y_pred_svm)\n",
    "\n",
    "print(f\"Random Forest Accuracy: {acc_rf:.4f}\")\n",
    "print(f\"SVM Accuracy: {acc_svm:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Confusion Matrices"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Random Forest\n",
    "cm_rf = confusion_matrix(y_test, y_pred_rf)\n",
    "sns.heatmap(cm_rf, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=emotions, yticklabels=emotions, ax=axes[0])\n",
    "axes[0].set_title('Random Forest - Confusion Matrix')\n",
    "axes[0].set_ylabel('True Label')\n",
    "axes[0].set_xlabel('Predicted Label')\n",
    "\n",
    "# SVM\n",
    "cm_svm = confusion_matrix(y_test, y_pred_svm)\n",
    "sns.heatmap(cm_svm, annot=True, fmt='d', cmap='Greens',\n",
    "            xticklabels=emotions, yticklabels=emotions, ax=axes[1])\n",
    "axes[1].set_title('SVM - Confusion Matrix')\n",
    "axes[1].set_ylabel('True Label')\n",
    "axes[1].set_xlabel('Predicted Label')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('/app/eeg_emotion_recognition_1806/results/confusion_matrices.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Classification Reports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"RANDOM FOREST - CLASSIFICATION REPORT\")\n",
    "print(\"=\"*60)\n",
    "print(classification_report(y_test, y_pred_rf, target_names=emotions))\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"SVM - CLASSIFICATION REPORT\")\n",
    "print(\"=\"*60)\n",
    "print(classification_report(y_test, y_pred_svm, target_names=emotions))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. ROC Curves"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Binarize labels for ROC\n",
    "y_test_bin = label_binarize(y_test, classes=[0, 1, 2])\n",
    "n_classes = y_test_bin.shape[1]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "colors = ['blue', 'green', 'red']\n",
    "\n",
# Random Forest ROC
for i, color in zip(range(n_classes), colors):
    fpr, tpr, _ = roc_curve(y_test_bin[:, i], y_prob_rf[:, i])
    roc_auc = auc(fpr, tpr)
    axes[0].plot(fpr, tpr, color=color, lw=2,
            label=f'{emotions[i]} (AUC = {roc_auc:.3f})')

axes[0].plot([0, 1], [0, 1], 'k--', lw=2)
axes[0].set_xlim([0.0, 1.0])
axes[0].set_ylim([0.0, 1.05])
axes[0].set_xlabel('False Positive Rate')
axes[0].set_ylabel('True Positive Rate')
axes[0].set_title('Random Forest - ROC Curves')
axes[0].legend(loc='lower right')
axes[0].grid(True)

# SVM - No ROC (no probability)
axes[1].text(0.5, 0.5, 'SVM trained without probability=True\nROC curves not available', 
             ha='center', va='center', fontsize=12)
axes[1].set_title('SVM - ROC Curves (N/A)')
axes[1].set_xlabel('False Positive Rate')
axes[1].set_ylabel('True Positive Rate')
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('/app/eeg_emotion_recognition_1806/results/roc_curves.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Feature Importance (Random Forest)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get feature importances\n",
    "importances = model_rf.feature_importances_\n",
    "indices = np.argsort(importances)[-20:]  # Top 20 features\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.barh(range(20), importances[indices], align='center')\n",
    "plt.yticks(range(20), [f'Feature {i}' for i in indices])\n",
    "plt.xlabel('Importance')\n",
    "plt.title('Top 20 Feature Importances (Random Forest)')\n",
    "plt.tight_layout()\n",
    "plt.savefig('/app/eeg_emotion_recognition_1806/results/feature_importance.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Summary Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate per-class metrics\n",
    "precision_rf, recall_rf, f1_rf, _ = precision_recall_fscore_support(y_test, y_pred_rf, average=None)\n",
    "precision_svm, recall_svm, f1_svm, _ = precision_recall_fscore_support(y_test, y_pred_svm, average=None)\n",
    "\n",
    "# Create summary table\n",
    "summary_data = []\n",
    "for i, emotion in enumerate(emotions):\n",
    "    summary_data.append({\n",
    "        'Emotion': emotion,\n",
    "        'RF Precision': f'{precision_rf[i]:.4f}',\n",
    "        'RF Recall': f'{recall_rf[i]:.4f}',\n",
    "        'RF F1': f'{f1_rf[i]:.4f}',\n",
    "        'SVM Precision': f'{precision_svm[i]:.4f}',\n",
    "        'SVM Recall': f'{recall_svm[i]:.4f}',\n",
    "        'SVM F1': f'{f1_svm[i]:.4f}'\n",
    "    })\n",
    "\n",
    "import pandas as pd\n",
    "summary_df = pd.DataFrame(summary_data)\n",
    "print(\"\\nPer-Class Metrics:\")\n",
    "print(summary_df.to_string(index=False))\n",
    "\n",
    "print(f\"\\nOverall Accuracy:\")\n",
    "print(f\"  Random Forest: {acc_rf:.4f}\")\n",
    "print(f\"  SVM: {acc_svm:.4f}\")\n",
    "\n",
    "# Macro averages\n",
    "macro_f1_rf = np.mean(f1_rf)\n",
    "macro_f1_svm = np.mean(f1_svm)\n",
    "print(f\"\\nMacro-Averaged F1-Score:\")\n",
    "print(f\"  Random Forest: {macro_f1_rf:.4f}\")\n",
    "print(f\"  SVM: {macro_f1_svm:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Save Evaluation Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save evaluation metrics\n",
    "evaluation_results = {\n",
    "    'random_forest': {\n",
    "        'accuracy': float(acc_rf),\n",
    "        'precision': precision_rf.tolist(),\n",
    "        'recall': recall_rf.tolist(),\n",
    "        'f1_score': f1_rf.tolist(),\n",
    "        'macro_f1': float(macro_f1_rf)\n",
    "    },\n",
    "    'svm': {\n",
    "        'accuracy': float(acc_svm),\n",
    "        'precision': precision_svm.tolist(),\n",
    "        'recall': recall_svm.tolist(),\n",
    "        'f1_score': f1_svm.tolist(),\n",
    "        'macro_f1': float(macro_f1_svm)\n",
    "    },\n",
    "    'emotions': emotions,\n",
    "    'test_samples': len(y_test)\n",
    "}\n",
    "\n",
    "with open('/app/eeg_emotion_recognition_1806/results/evaluation_metrics.pkl', 'wb') as f:\n",
    "    pickle.dump(evaluation_results, f)\n",
    "\n",
    "print(\"Evaluation results saved to /app/eeg_emotion_recognition_1806/results/evaluation_metrics.pkl\")"
   ]
  }
 ],
